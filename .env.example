# ListBridge Configuration
# Copy this file to .env and fill in your values

# Flask secret key (generate with: python -c "import secrets; print(secrets.token_hex(32))")
SECRET_KEY=change-me-to-a-random-secret-key

# Plex configuration
PLEX_URL=http://localhost:32400
PLEX_TOKEN=your-plex-token-here
PLEX_MUSIC_LIBRARY=Music

# Navidrome configuration (Subsonic-compatible API)
NAVIDROME_URL=http://localhost:4533
NAVIDROME_USER=admin
NAVIDROME_PASSWORD=your-navidrome-password

# Path prefix mapping (optional)
# If Plex sees files under a different path than ListBridge, set these.
# e.g. Plex sees /data/music but ListBridge/m3u files use /mnt/music
PLEX_PATH_PREFIX=
LOCAL_PATH_PREFIX=

# Directory where your .m3u files are stored
M3U_DIRECTORY=/path/to/your/playlists

# How often to poll Plex for playlist changes (seconds)
PLEX_POLL_INTERVAL=60

# Port for the web UI
PORT=5000
